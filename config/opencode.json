{
  "$schema": "https://opencode.ai/config.json",
  "model": "ollama/__PI_AGENT_MODEL__",
  "small_model": "ollama/__PI_AGENT_SMALL_MODEL__",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama",
      "options": {
        "baseURL": "http://localhost:11434/v1",
        "timeout": 600000,
        "chunkTimeout": 60000
      },
      "models": {
        "__PI_AGENT_MODEL__": {
          "name": "Pi Agent Reasoning",
          "tool_call": true,
          "limit": { "context": __PI_AGENT_CONTEXT__, "output": 8192 }
        },
        "__PI_AGENT_SMALL_MODEL__": {
          "name": "Pi Agent Small",
          "tool_call": true,
          "limit": { "context": 32768, "output": 4096 }
        }
      }
    }
  }
}
